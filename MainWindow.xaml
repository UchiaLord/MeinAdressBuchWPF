<Window x:Class="MeinAdressBuchWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeinAdressBuchWPF"
        mc:Ignorable="d"
        Title="MeinAdressbuch" 
        Height="600" 
        Width="900">
     
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock 
            Grid.Row="0"
            Text="Mein Adressbuch" 
            FontSize="26" 
            FontWeight="Bold" 
            Margin="0,0,0,20"
        />
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Vorname:" Margin="0,0,10,10"/>
            <TextBox x:Name="VornameTextBox" Grid.Row="0" Grid.Column="1" Margin="0 0 20 10"/>
            
            <TextBlock Grid.Row="0" Grid.Column="2" Text="Nachname:" Margin="0,0,10,10"/>
            <TextBox x:Name="NachnameTextBox" Grid.Row="0" Grid.Column="3" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Geburtsdatum:" Margin="0,0,10,10"/>
            <DatePicker x:Name="GeburtsdatumTextBox" Grid.Row="1" Grid.Column="1" Margin="0,0,20,10"/>

            <TextBlock Grid.Row="1" Grid.Column="2" Text="Adresse:" Margin="0,0,10,10"/>
            <TextBox x:Name="AdresseTextBox" Grid.Row="1" Grid.Column="3" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="PLZ:" Margin="0,0,10,10"/>
            <TextBox x:Name="PLZTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,20,10"/>

            <TextBlock Grid.Row="2" Grid.Column="2" Text="Telefonnummer:" Margin="0,0,10,10"/>
            <TextBox x:Name="TelefonnummerTextBox" Grid.Row="2" Grid.Column="3" Margin="0,0,0,10"/>
        </Grid>

        <DataGrid
            x:Name="PersonenDataGrid"
            Grid.Row="2"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            SelectionMode="Single"
            SelectionChanged="PersonenDataGrid_SelectionChanged">


            <DataGrid.Columns>
                <DataGridTextColumn Header="Vorname" Binding="{Binding Vorname}" Width="*"/>
                <DataGridTextColumn Header="Nachname" Binding="{Binding Nachname}" Width="*"/>
                <DataGridTextColumn Header="Geburtsdatum" Binding="{Binding Geburtsdatum}" Width="*"/>
                <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="*"/>
                <DataGridTextColumn Header="PLZ" Binding="{Binding Postleitzahl}" Width="*"/>
                <DataGridTextColumn Header="Telefonnummer" Binding="{Binding Telefonnummer}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="3" Orientation="Horizontal">
            <Button x:Name="HinzufuegenButton" Content="Hinzufügen" Width="110" Margin="0,0,10,0" Click="HinzufuegenButton_Click"/>
            <Button x:Name="BearbeitenButton" Content="Bearbeiten" Width="110" Margin="0,0,10,0" Click="BearbeitenButton_Click"/>
            <Button x:Name="LoeschenButton" Content="Löschen" Width="110" Click="LoeschenButton_Click"/>
            <Button x:Name="LadenButton" Content="Laden" Width="110" Click="LadenButton_Click"/>
            <Button x:Name="SpeichernButton" Content="Speichern" Width="110" Click="SpeichernButton_Click"/>
            <TextBlock x:Name="StatusTextBlock" VerticalAlignment="Center" Margin="20 0 0 0" Text="Bereit."/>
        </StackPanel>
    </Grid>
</Window>
